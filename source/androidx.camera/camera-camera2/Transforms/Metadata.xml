<metadata>
    <!-- Preserve non-standard namespace remapping -->
    <attr 
        path="/api/package[@name='androidx.camera.camera2.impl']" 
        name="managedName"
        >
        AndroidX.Camera.Camera2
    </attr>
    
    <!-- Preserve missing period for backwards compatbility -->
    <attr 
        path="/api/package[@name='androidx.camera.camera2.internal.compat.params']" 
        name="managedName"
        >
        AndroidX.Camera.Camera2Internal.Compat.Params
    </attr>    

    <!-- Preserve non-preferred "InterOp" capitalization for backwards compatbility -->
    <attr 
        path="/api/package[@name='androidx.camera.camera2.interop']" 
        name="managedName"
        >
        AndroidX.Camera.Camera2.InterOp
    </attr>
    
    <remove-node path="/api/package/class/implements[@name='androidx.camera.core.ConfigProvider']" />
    
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='ImageAnalysisConfigProvider']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='VideoCaptureConfigProvider']/implements"
        />
    
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='ImageCaptureConfigProvider']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.impl']/class[@name='Camera2ImplConfig.Builder']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='PreviewConfigProvider']/implements"
        />
    
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.impl']/class[@name='Camera2ImplConfig']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='MeteringRepeatingConfig']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='MeteringRepeatingConfig.Builder']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.interop']/class[@name='CaptureRequestOptions.Builder']/implements"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.interop']/class[@name='CaptureRequestOptions']/implements"
        />

    <attr 
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='Camera2CameraFactory']/method[@name='getCameraManager' and count(parameter)=0]" 
        name="managedReturn"
        >
        Java.Lang.Object
    </attr>
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='Camera2CameraInfoImpl']"
        />
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='Camera2CameraControlImpl']"
        />

    <attr
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='Camera2PresenceSource']/method[@name='startMonitoring' and count(parameter)=0]"
        name="visibility"
        >
        protected
    </attr>
    <attr
        path="/api/package[@name='androidx.camera.camera2.internal']/class[@name='Camera2PresenceSource']/method[@name='stopMonitoring' and count(parameter)=0]"
        name="visibility"
        >
        protected
    </attr>

    <!-- PipeCameraPresenceSource.stopMonitoring is public in Java but the base class
         AbstractCameraPresenceSource.stopMonitoring is protected — fix visibility to avoid CS0507 -->
    <attr
        path="/api/package[@name='androidx.camera.camera2.adapter']/class[@name='PipeCameraPresenceSource']/method[@name='stopMonitoring' and count(parameter)=0]"
        name="visibility"
        >
        protected
    </attr>

    <!-- CameraInternalAdapter implements CameraInternal which inherits ICamera requiring CameraControl
         and CameraInfo properties that are exposed as covariant subtypes — remove implements (CS0535) -->
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.adapter']/class[@name='CameraInternalAdapter']/implements"
        />

    <!-- ZoomValue implements IZoomState but is missing LinearZoom property (CS0535) -->
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.adapter']/class[@name='ZoomValue']/implements"
        />

    <!-- MeteringRepeating extends UseCase but is missing new abstract members added in 1.6.0 (CS0534)
         and its Builder has IUseCaseConfigBuilder return type mismatches (CS0738) — remove both -->
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.impl']/class[@name='MeteringRepeating']"
        />

    <!-- RejectOperationCameraCaptureSession extends CameraCaptureSession but does not implement
         new abstract members added in Android API 36 — remove to avoid CS0534 -->
    <remove-node
        path="/api/package[@name='androidx.camera.camera2.impl']/class[@name='RejectOperationCameraCaptureSession']"
        />

</metadata>