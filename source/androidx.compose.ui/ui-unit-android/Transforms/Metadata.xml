  <!--
    `Dp` is a Kotlin `@JvmInline value class … : Comparable<Dp>`. Because the
    inline `Dp` parameter lowers to a raw `float` at the JNI boundary, the
    generated `compareTo(float)` cannot satisfy `java.lang.Comparable.compareTo(Object)`
    (CS0535). Drop the `Comparable` interface so the class still binds (and its
    `Companion` constants stay reachable). Mirrors the inline-class lowering
    caveat from androidx.compose.ui/ui-graphics-android.
  -->
  <remove-node path="/api/package[@name='androidx.compose.ui.unit']/class[@name='Dp']/implements[@name='java.lang.Comparable']" />

